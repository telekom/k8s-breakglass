{
  "name": "breakglass",
  "version": "0.0.0",
  "engines": {
    "node": ">=24.11.0"
  },
  "overrides": {
    "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
    "vitest": "$vitest",
    "@vitest/coverage-v8": "$@vitest/coverage-v8"
  },
  "scripts": {
    "dev": "vite",
    "dev:mock": "cross-env VITE_USE_MOCK_AUTH=true concurrently -k -n api,ui -c magenta,cyan \"npm:mock-api\" \"npm:dev\"",
    "dev:real": "cross-env VITE_USE_MOCK_AUTH=false vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --port 5050",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:screenshots": "playwright test",
    "test:screenshots:update": "playwright test --update-snapshots",
    "test:a11y": "playwright test --config=playwright.a11y.config.ts",
    "test:e2e": "playwright test --config=playwright.e2e.config.ts",
    "test:e2e:ui": "playwright test --config=playwright.e2e.config.ts --ui",
    "test:e2e:debug": "playwright test --config=playwright.e2e.config.ts --debug",
    "test:e2e:report": "playwright show-report playwright-report-e2e",
    "mock-api": "node --watch mock-api/server.mjs"
  },
  "dependencies": {
    "@telekom/scale-components": "3.0.0-beta.161",
    "@telekom/scale-components-neutral": "3.0.0-beta.160",
    "axios": "^1.18.1",
    "humanize-duration": "^3.34.0",
    "jose": "^6.2.3",
    "oidc-client-ts": "^3.5.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@rollup/plugin-dynamic-import-vars": "^2.1.5",
    "@tsconfig/node22": "^22.0.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/humanize-duration": "^3.27.4",
    "@vitejs/plugin-legacy": "^8.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "express": "^5.2.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.58.2",
    "prettier": "^3.9.4",
    "terser": "^5.48.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  }
}
