# Tool versions - Single source of truth for CI and local development
# Used by the Makefile (via include) and indirectly by CI workflows through Make targets
# Override on the command line: make KUSTOMIZE_VERSION=v5.9.0 kustomize

# Build tools
KUSTOMIZE_VERSION=v5.8.1
CONTROLLER_TOOLS_VERSION=v0.21.0
# setup-envtest publishes semver tags; pin one so envtest installs are reproducible.
# Update by running: go list -m -json sigs.k8s.io/controller-runtime/tools/setup-envtest@latest
ENVTEST_VERSION=v0.24.1
# Should track the same minor version as KIND_NODE_IMAGE in CI (patch may differ based on envtest availability)
ENVTEST_K8S_VERSION=1.36.0
GOLANGCI_LINT_VERSION=v2.12.2
GOVULNCHECK_VERSION=v1.4.0
